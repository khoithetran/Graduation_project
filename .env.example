# Copy this file to .env and adjust values for your environment
# .env is gitignored — never commit real values

MODEL_PATH=/app/models/yolov8s_ap.onnx
CONFIDENCE_THRESHOLD=0.25
PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:8000

# ── ONNX Runtime execution provider ──────────────────────────────────────────
# Leave empty (default) for auto-detection: uses CUDAExecutionProvider when
# onnxruntime-gpu is installed and a CUDA device is available, otherwise CPU.
# Set explicitly to force a specific provider:
#   ONNX_EXECUTION_PROVIDER=CPUExecutionProvider   # force CPU even on GPU machines
#   ONNX_EXECUTION_PROVIDER=CUDAExecutionProvider  # force CUDA (requires onnxruntime-gpu)
# NOTE: The default requirements.txt ships onnxruntime (CPU-only). To enable GPU
# inference for ONNX models, replace it with onnxruntime-gpu in requirements.txt.
# ONNX_EXECUTION_PROVIDER=

# ── Person-first pipeline (off by default) ───────────────────────────────────
# Set PERSON_FIRST_ENABLED=true to activate the two-stage person→helmet pipeline.
# Supports both .pt and .onnx person models.
# Default model: yolov8n.pt (auto-downloaded by Ultralytics on first run).
# ONNX person model example: PERSON_MODEL_PATH=models/yolov8n.onnx
#   Export from .pt: python -c "from ultralytics import YOLO; YOLO('yolov8n.pt').export(format='onnx')"
PERSON_FIRST_ENABLED=false
# PERSON_MODEL_PATH=models/yolov8n.pt    # default: auto-downloaded yolov8n.pt
# PERSON_MODEL_PATH=models/yolov8n.onnx  # ONNX variant for faster CPU-only deploys
PERSON_CONFIDENCE_THRESHOLD=0.40         # person detection confidence threshold

# ── Performance tuning (accuracy-safe defaults) ──────────────────────────────
# PERSON_DETECTION_INTERVAL: run person detection once every N processed frames.
# Default=1 (every frame, full accuracy).  On weak CPU deployments, increase to
# 2–4 to reduce person-model calls; helmet re-checks still happen per-frame via
# the helmet cache.  Trade-off: brief lag when a new person enters the frame.
PERSON_DETECTION_INTERVAL=1

HELMET_RECHECK_INTERVAL=5               # re-run helmet model every N frames per track
PERSON_CROP_MARGIN=0.05                 # fractional margin added around the crop
UPPER_BODY_CROP_RATIO=0.60              # top fraction of person bbox used for crop
